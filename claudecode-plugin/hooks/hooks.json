{
  "description": "Marut security validation hooks",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "\"${CLAUDE_PLUGIN_ROOT}/marut-wrapper.sh\"",
            "timeout": 5,
            "statusMessage": "Validating command with Marut..."
          }
        ]
      }
    ]
  }
}
